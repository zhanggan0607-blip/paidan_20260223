# SSTCP 维保系统 - 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# 应用配置
APP_NAME=SSTCP Maintenance System
APP_VERSION=2.0.8
DEBUG=False

# 安全配置（必填）
# 生成方法: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production

# 数据库配置（必填）
DATABASE_URL=postgresql://sstcp_user:your-password@your-db-host:5432/tq

# Redis配置
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true
REDIS_CACHE_TTL=3600

# API配置
API_PREFIX=/api/v1
DOCS_URL=/api/docs
REDOC_URL=/api/redoc
OPENAPI_URL=/api/openapi.json
SERVER_BASE_URL=http://localhost:8000

# CORS配置
CORS_ORIGINS=https://www.paidan.sstcp.top,https://paidan.sstcp.top,http://localhost:5173,http://localhost:5180

# 阿里云OCR配置
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_OCR_REGION_ID=cn-shanghai

# 阿里云OSS配置
ALIYUN_OSS_ACCESS_KEY_ID=your-oss-access-key-id
ALIYUN_OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
ALIYUN_OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
ALIYUN_OSS_BUCKET_NAME=sstcp-uploads
ALIYUN_OSS_CDN_DOMAIN=
ALIYUN_OSS_ENABLED=true

# 钉钉集成配置
DINGTALK_AGENT_ID=
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
