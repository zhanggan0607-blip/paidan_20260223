APP_NAME=SSTCP Maintenance System
APP_VERSION=1.0.0
DEBUG=False

# Database Configuration
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/tq?client_encoding=utf8

API_PREFIX=/api/v1
DOCS_URL=/api/docs
REDOC_URL=/api/redoc
OPENAPI_URL=/api/openapi.json

# CORS Configuration
CORS_ORIGINS="http://localhost:3000,http://localhost:4173,http://localhost:5173"

# JWT Configuration
# Generate with: openssl rand -hex 32
SECRET_KEY=YOUR_SECRET_KEY_HERE

PAGE_SIZE=10
MAX_PAGE_SIZE=1000
PORT=8000

# Aliyun OCR Configuration
ALIYUN_ACCESS_KEY_ID=YOUR_ALIYUN_ACCESS_KEY_ID
ALIYUN_ACCESS_KEY_SECRET=YOUR_ALIYUN_ACCESS_KEY_SECRET
ALIYUN_OCR_REGION_ID=cn-shanghai
