{
  "name": "@sstcp/shared",
  "version": "1.0.0",
  "description": "SSTCP维保管理系统共享代码库",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "generate:types": "openapi-typescript http://localhost:8000/openapi.json -o src/types/generated.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./utils": {
      "types": "./src/utils/index.ts",
      "import": "./src/utils/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "import": "./src/types/index.ts"
    },
    "./api": {
      "types": "./src/api/index.ts",
      "import": "./src/api/index.ts"
    },
    "./api/endpoints": {
      "types": "./src/api/endpoints.ts",
      "import": "./src/api/endpoints.ts"
    },
    "./utils/format": {
      "types": "./src/utils/format.ts",
      "import": "./src/utils/format.ts"
    },
    "./utils/searchHistory": {
      "types": "./src/utils/searchHistory.ts",
      "import": "./src/utils/searchHistory.ts"
    },
    "./utils/secureStorage": {
      "types": "./src/utils/secureStorage.ts",
      "import": "./src/utils/secureStorage.ts"
    },
    "./utils/watermark": {
      "types": "./src/utils/watermark.ts",
      "import": "./src/utils/watermark.ts"
    },
    "./utils/status": {
      "types": "./src/utils/status.ts",
      "import": "./src/utils/status.ts"
    },
    "./types/api": {
      "types": "./src/types/api.ts",
      "import": "./src/types/api.ts"
    },
    "./types/permission": {
      "types": "./src/types/permission.ts",
      "import": "./src/types/permission.ts"
    },
    "./api/request": {
      "types": "./src/api/request.ts",
      "import": "./src/api/request.ts"
    }
  },
  "dependencies": {
    "axios": "^1.7.7",
    "crypto-js": "^4.2.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "openapi-typescript": "^7.0.0",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "axios": "^1.7.0"
  }
}
